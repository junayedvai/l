{
  "buildCommand": "npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/api/admin-panel"
    }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
